@model MySolution.DataLayers.Employee

@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Thêm nhân viên mới</h3>
        </div>
        <div class="card-body">
            @* Form này sẽ gửi dữ liệu về hàm Create trong Controller khi bấm Lưu *@
            <form asp-action="Create" method="post">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mã Nhân Viên (*)</label>
                        <input asp-for="EmployeeId" class="form-control" placeholder="Ví dụ: NV001" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Phòng ban</label>
                        <input asp-for="Department" class="form-control" placeholder="Ví dụ: IT, Kế toán..." />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Họ (First Name)</label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tên (Last Name)</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ngày sinh</label>
                        <input asp-for="BirthDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-save"></i> Lưu lại
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>