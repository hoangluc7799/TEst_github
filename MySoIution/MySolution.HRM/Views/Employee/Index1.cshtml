@model MySolution.DataLayers.Employee

@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="container mt-4">
    <h2>Thêm nhân viên mới</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            @* Form gửi dữ liệu về Action Create của Employee *@
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label">Mã Nhân Viên</label>
                    <input asp-for="EmployeeId" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Họ (First Name)</label>
                    <input asp-for="FirstName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên (Last Name)</label>
                    <input asp-for="LastName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ngày sinh</label>
                    <input asp-for="BirthDate" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Phòng ban</label>
                    <input asp-for="Department" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" />
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Lưu lại</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>